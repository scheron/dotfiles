{
  "show_completion_documentation": false,
  "diagnostics": {
    "inline": {
      "enabled": false
    }
  },
  "diff_view_style": "unified",
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "format_on_save": "off",
  "edit_predictions": {
    "provider": "zed",
    "mode": "eager",
  },
  "current_line_highlight": "gutter",
  "multi_cursor_modifier": "cmd_or_ctrl",
  "icon_theme": {
    "mode": "light",
    "light": "Symbols Icon Theme",
    "dark": "Symbols Icon Theme"
  },
  "autosave": "off",
  "ui_font_family": "Dank Mono",
  "ui_font_size": 20.0,
  "buffer_font_family": "Dank Mono",
  "buffer_font_size": 20.0,
  "buffer_line_height":{
    "custom": 1.7
  },
  "drag_and_drop_selection": {
    "enabled": false
  },
  "seed_search_query_from_cursor":"never",
  "show_whitespaces": "none",


  "use_system_path_prompts": true,
  "use_system_prompts": true,
  "tab_size": 2,
  "inline_code_actions": false,
  "vim_mode": true,
  "vertical_scroll_margin": 4,
  "when_closing_with_no_tabs":"keep_window_open",
  "close_on_file_delete": true,
  "restore_on_file_reopen": false,
  "restore_on_startup":"empty_tab",
  "lsp_document_colors":"border",
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Duskfox - blurred"
  },
  "base_keymap": "VSCode",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim": {
    "use_smartcase_find": true,
  },
  "relative_line_numbers": "wrapped",
  "toolbar": {
    "selections_menu": false,
    "agent_review": false,
    "quick_actions": false,
  },
  "scrollbar": {
    "show": "never",
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "errors",
  },
  "centered_layout": {
    "left_padding": 0.15,
    "right_padding": 0.15,
  },
  "language_models": {
    "ollama": {
      "api_url": "http://localhost:11434",
    },
  },
  // EDITOR
  "inlay_hints": {
    "enabled": false,
    "show_value_hints": false,
    "show_type_hints": false,
    "show_other_hints": false,
  },
  "gutter":{
    "min_line_number_digits": 0,
    "folds": false,
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  // LSP
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "classAttributes": ["class", "className", "ngClass", "styles"],
      },
    },
  },
  "languages": {
    // Refer https://zed.dev/docs/languages/javascript and https://zed.dev/docs/languages/typescript for more info
    "TypeScript": {
      // Refer https://github.com/jellydn/ts-inlay-hints for how to setup for Neovim and VSCode
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": false,
        "show_other_hints": true,
        "show_type_hints": true,
      },
    },
  },
  "terminal": {
    "dock": "left",
    "font_family": "VictorMono Nerd Font Mono",
    "env": {
      "EDITOR": "zed --wait",
    },
  },
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"],
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    // above is default from Zed
    "**/out",
    "**/dist",
    "**/.husky",
    "**/.turbo",
    "**/.vscode-test",
    "**/.vscode",
    "**/.next",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/report",
    "**/node_modules",
  ],
  // PANELS
  "project_panel": {
    "button": true,
    "dock": "left",
    "git_status": true,
    "default_width": 400,
    "hide_root": true,
    "auto_fold_dirs": false,
    "starts_open": false,
    "sticky_scroll": false,
    "scrollbar": {
      "show": "never",
    },
    "indent_guides": {
      "show": "never",
    },
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "notification_panel": {
    "dock": "right",
  },
  "file_finder": {
    "modal_max_width": "large",
  },
  "git_panel": {
    "tree_view": true,
    "dock": "right",
  },
  "agent":{
    "sidebar_side": "right",
    "dock": "right",
    "default_view":null
  }
}
